# Copy this file to .env and fill in real values from your Firebase
# project's console (Project settings -> General -> Your apps -> SDK
# setup and configuration -> Config). See the chat instructions for the
# full step-by-step.
#
# If these are left blank, the app runs entirely in guest mode - sign-in
# and cloud backup are simply unavailable, everything else works exactly
# as before.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
